#!/usr/bin/env bash
# ==============================================================================
# 🚀 Ray Pterodactyl Uninstaller (Pro Edition)
# ==============================================================================
# 👑 Developed by Ray
# 🏢 Ray Industries | 📺 YouTube: @RayVerse
# ⚡ Powered by Bash + Linux Automation
# ==============================================================================

set -e
IFS=$'\n\t'

# ==============================================================================
# 🎨 UI & STYLING (Ray's Signature Style)
# ==============================================================================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color
BOLD='\033[1m'

ok() { echo -e "${GREEN}✅ $1${NC}"; }
info() { echo -e "${CYAN}ℹ️  $1${NC}"; }
warn() { echo -e "${YELLOW}⚠️  $1${NC}"; }
err() { echo -e "${RED}❌ $1${NC}"; }
step() { echo -e "\n${MAGENTA}⚡ ${BOLD}$1${NC}"; }

pause() {
    echo -e "\n${CYAN}Press [ENTER] to return to menu...${NC}"
    read -r -s
}

show_banner() {
    clear
    echo -e "${CYAN}${BOLD}"
    echo "================================================================"
    echo " 🚀 Ray Pterodactyl Uninstaller "
    echo " 👑 Developed by Ray | 🏢 Ray Industries | 📺 @RayVerse"
    echo "================================================================${NC}"
    echo ""
}

# ==============================================================================
# 🛡️ INIT & CHECKS
# ==============================================================================
if [ "$EUID" -ne 0 ]; then
    echo -e "${RED}${BOLD}❌ This script must be run as root! Try running with 'sudo'.${NC}"
    exit 1
fi

confirm_action() {
    local message="$1"
    echo ""
    echo -e "${RED}${BOLD}================================================================${NC}"
    echo -e "${RED}${BOLD}                       ⚡ DANGER ZONE ⚡                        ${NC}"
    echo -e "${RED}${BOLD} $message ${NC}"
    echo -e "${RED}${BOLD}================================================================${NC}"
    echo ""
    read -p "Are you ABSOLUTELY sure? Type 'YES' to continue: " REPLY
    if [[ "$REPLY" == "YES" ]]; then
        return 0
    else
        echo ""
        ok "Operation cancelled safely."
        return 1
    fi
}

# ==============================================================================
# 🧹 CORE REMOVAL LOGIC
# ==============================================================================
cleanup_nginx() {
    step "Cleaning Pterodactyl Nginx configurations..."
    rm -f /etc/nginx/sites-enabled/pterodactyl.conf 2>/dev/null && ok "Removed sites-enabled config"
    rm -f /etc/nginx/sites-available/pterodactyl.conf 2>/dev/null && ok "Removed sites-available config"
    rm -f /etc/nginx/conf.d/pterodactyl.conf 2>/dev/null && ok "Removed conf.d config"
    
    if command -v nginx >/dev/null 2>&1; then
        systemctl restart nginx >/dev/null 2>&1 && ok "Nginx restarted"
    fi
}

do_uninstall_panel() {
    step "Stopping queue worker..."
    systemctl stop pteroq.service 2>/dev/null || true
    systemctl disable pteroq.service 2>/dev/null || true
    rm -f /etc/systemd/system/pteroq.service
    systemctl daemon-reload
    ok "Queue worker removed"

    step "Removing cron job..."
    (crontab -l 2>/dev/null | grep -v '/var/www/pterodactyl/artisan schedule:run') | crontab - 2>/dev/null || true
    ok "Cron job cleared"

    step "Deleting panel files..."
    rm -rf /var/www/pterodactyl
    ok "Panel directory removed"

    step "Dropping database and user..."
    mysql -e "DROP DATABASE IF EXISTS panel;" 2>/dev/null || true
    mysql -e "DROP USER IF EXISTS 'pterodactyl'@'127.0.0.1';" 2>/dev/null || true
    mysql -e "FLUSH PRIVILEGES;" 2>/dev/null || true
    ok "Database cleaned"

    cleanup_nginx
}

do_uninstall_wings() {
    step "Stopping Wings service..."
    systemctl stop wings 2>/dev/null || true
    systemctl disable wings 2>/dev/null || true
    rm -f /etc/systemd/system/wings.service
    systemctl daemon-reload
    ok "Wings service removed"

    step "Deleting Wings data..."
    rm -rf /etc/pterodactyl /var/lib/pterodactyl /var/log/pterodactyl
    rm -f /usr/local/bin/wings /usr/local/bin/wing
    ok "All Wings files removed"
}

# ==============================================================================
# 📦 MENU WRAPPERS
# ==============================================================================
uninstall_panel() {
    show_banner
    echo -e "${MAGENTA}--- 🗑️  Uninstalling Pterodactyl Panel ---${NC}"
    if confirm_action "This will PERMANENTLY delete the Panel, database, and all servers."; then
        do_uninstall_panel
        echo ""
        ok "Pterodactyl Panel completely uninstalled!"
    fi
    pause
}

uninstall_wings() {
    show_banner
    echo -e "${MAGENTA}--- 🦅 Uninstalling Pterodactyl Wings ---${NC}"
    if confirm_action "This will PERMANENTLY delete Wings and all server data/volumes."; then
        do_uninstall_wings
        echo ""
        ok "Pterodactyl Wings completely uninstalled!"
    fi
    pause
}

uninstall_both() {
    show_banner
    echo -e "${MAGENTA}--- ☢️  Nuclear Option: Panel + Wings ---${NC}"
    if confirm_action "This will ERASE EVERYTHING: Panel, Wings, databases, servers."; then
        do_uninstall_panel
        do_uninstall_wings
        echo ""
        ok "Full Pterodactyl system has been obliterated."
    fi
    pause
}

# ==============================================================================
# 📋 MAIN MENU LOOP
# ==============================================================================
while true; do
    show_banner
    echo -e "${YELLOW}⚡ Pterodactyl Uninstaller (Danger Zone)${NC}"
    echo "1) 🗑️  Uninstall Panel Only"
    echo "2) 🦅 Uninstall Wings Only"
    echo "3) ☢️  Uninstall Panel + Wings (Nuclear)"
    echo "0) ❌ Exit Uninstaller"
    echo ""
    warn "All actions are IRREVERSIBLE. Data will be permanently deleted!"
    echo ""
    
    read -p "Choose option [0-3]: " choice

    case "$choice" in
        1) uninstall_panel ;;
        2) uninstall_wings ;;
        3) uninstall_both ;;
        0) 
            show_banner
            ok "Exiting uninstaller safely. Goodbye!"
            exit 0
            ;;
        *) 
            err "Invalid choice! Please select 0–3."
            sleep 2
            ;;
    esac
done
